<body>

<div class="top-bar">
  <a href="https://payhip.com/ThePromptSanctum">The Prompt Sanctum — AI tools for trades contractors ↗</a>
</div>

<div class="page">
  <h1>How much are missed calls costing you?</h1>
  <p class="sub">Move the sliders. See your real number in seconds — free.</p>

  <div class="testimonial">
    <p class="test-text">"I thought I was missing maybe 2-3 calls a week. This showed me it was closer to 9. Set up the fix in a weekend — recovered $1,200 in the first week."</p>
    <p class="test-attr">Marco Rivera · Rivera HVAC · Riverside, CA</p>
  </div>

  <div class="field-group">
    <label>Your trade</label>
    <div class="trade-grid">
      <button class="sel-btn selected" id="trade-HVAC" onclick="selectTrade('HVAC',350)"><span class="btn-title">HVAC</span><span class="btn-sub">$350 avg missed lead</span></button>
      <button class="sel-btn" id="trade-Plumbing" onclick="selectTrade('Plumbing',275)"><span class="btn-title">Plumbing</span><span class="btn-sub">$275 avg missed lead</span></button>
      <button class="sel-btn" id="trade-Electrical" onclick="selectTrade('Electrical',225)"><span class="btn-title">Electrical</span><span class="btn-sub">$225 avg missed lead</span></button>
      <button class="sel-btn" id="trade-Roofing" onclick="selectTrade('Roofing',800)"><span class="btn-title">Roofing</span><span class="btn-sub">$800 avg missed lead</span></button>
      <button class="sel-btn" id="trade-Cleaning" onclick="selectTrade('Cleaning',120)"><span class="btn-title">Cleaning</span><span class="btn-sub">$120 avg missed lead</span></button>
      <button class="sel-btn" id="trade-Other" onclick="selectTrade('Other',300)"><span class="btn-title">Other</span><span class="btn-sub">$300 avg missed lead</span></button>
    </div>
  </div>

  <div class="field-group">
    <label>How many legitimate calls do you get per week?</label>
    <p class="field-hint">Real customers only — do not count spam, robocalls, or vendor calls</p>
    <div class="slider-wrap">
      <input type="range" min="5" max="100" step="1" value="20" id="calls-slider" oninput="updateCalc()">
      <span class="slider-val" id="calls-val">20/week</span>
    </div>
    <span class="warn-note">Tip: check your recent call log and subtract obvious spam numbers. Most contractors overestimate their real lead volume by 30-40%.</span>
  </div>

  <div class="field-group">
    <label>When you're on a job, who answers your calls?</label>
    <div class="staff-grid">
      <button class="sel-btn selected" id="staff-solo" onclick="selectStaff('solo',0.62)">
        <span class="btn-title">Just me</span>
        <span class="btn-sub">~62% go unanswered on job sites — Contractor Magazine 2024</span>
      </button>
      <button class="sel-btn" id="staff-office" onclick="selectStaff('office',0.27)">
        <span class="btn-title">I have office help</span>
        <span class="btn-sub">~27% still go unanswered — Invoca 2025</span>
      </button>
    </div>
  </div>

  <hr>

  <div class="gap-row">
    <div class="gap-card">
      <p class="gap-label">Voicemails you see</p>
      <p class="gap-value" id="voicemail-calls">1/week</p>
      <p class="gap-note">Most callers never leave one</p>
    </div>
    <div class="gap-card">
      <p class="gap-label">Leads actually lost</p>
      <p class="gap-value red" id="real-calls">4/week</p>
      <p class="gap-note">Already called your competitor</p>
    </div>
  </div>

  <div class="explain-box">
    <p class="explain-text" id="explain-text"></p>
  </div>

  <div class="main-card">
    <p class="main-label">Revenue walking out the door every month</p>
    <p class="main-monthly" id="monthly-loss">$0</p>
    <p class="main-annual" id="annual-loss">$0 per year</p>
  </div>
  <p class="source-line">Contractor Magazine 2024 · Invoca 2025 · Data from 1,200+ contractors (callbirdai.com) · 411 Locals 2024 study of 85 businesses</p>

  <div class="email-section">
    <p class="email-title">See the exact message Rivera HVAC sends to every missed caller — free</p>
    <p class="email-sub">One email. The template that recovered $1,200 in Week 1. No spam ever.</p>
    <div class="email-row">
      <input type="email" id="email-input" placeholder="your@email.com">
      <button onclick="submitEmail()">Send it</button>
    </div>
    <p class="email-confirm" id="email-confirm">On its way — check your inbox.</p>
  </div>

  <div class="cta-card">
    <p class="cta-title" id="cta-title">Get 5 messages personalized to your business — send tonight</p>
    <p class="cta-sub">Answer 6 questions. Get professional missed-call messages written for your exact trade, your name, and your service area. Copy and send immediately. Reuse for every missed call, forever.</p>
    <p class="cta-zero">Zero subscriptions required. Zero tech setup. $47 one-time.</p>
    <a class="cta-btn" href="https://payhip.com/ThePromptSanctum" target="_blank">Get my personalized messages — $47</a>
    <a class="demo-link" href="message-kit.html">Try the free message preview first</a>
  </div>

  <div class="footer">
    <p>© 2026 The Prompt Sanctum · <a href="https://payhip.com/ThePromptSanctum">payhip.com/ThePromptSanctum</a></p>
    <p style="margin-top:4px;">IndOp Series — AI tools built for independent operators</p>
  </div>
</div>

<script>
let tradeSelected = 'HVAC';
let leadValue = 350;
let missRate = 0.62;

function selectTrade(trade, val) {
  tradeSelected = trade;
  leadValue = val;
  document.querySelectorAll('[id^="trade-"]').forEach(b => b.classList.remove('selected'));
  document.getElementById('trade-' + trade).classList.add('selected');
  updateCalc();
}

function selectStaff(mode, rate) {
  missRate = rate;
  document.getElementById('staff-solo').classList.toggle('selected', mode === 'solo');
  document.getElementById('staff-office').classList.toggle('selected', mode === 'office');
  updateCalc();
}

function updateCalc() {
  const weeklyCalls = parseInt(document.getElementById('calls-slider').value);
  document.getElementById('calls-val').textContent = weeklyCalls + '/week';
  const totalMissed = Math.round(weeklyCalls * missRate);
  const newLeadsMissed = Math.round(totalMissed * 0.35);
  const voicemails = Math.max(1, Math.round(newLeadsMissed * 0.15));
  const monthlyLoss = Math.round(newLeadsMissed * 4.33 * leadValue * 0.20);
  const annualLoss = monthlyLoss * 12;
  const missRatePct = Math.round(missRate * 100);
  document.getElementById('voicemail-calls').textContent = voicemails + '/week';
  document.getElementById('real-calls').textContent = newLeadsMissed + '/week';
  document.getElementById('monthly-loss').textContent = '$' + monthlyLoss.toLocaleString();
  document.getElementById('annual-loss').textContent = '$' + annualLoss.toLocaleString() + ' per year';
  document.getElementById('explain-text').textContent =
    'Of your ' + weeklyCalls + ' weekly calls, roughly ' + totalMissed + ' go unanswered while you\'re working (' + missRatePct + '% miss rate). About ' + newLeadsMissed + ' of those are genuine new customer leads. Most never leave a voicemail — they call the next ' + tradeSelected.toLowerCase() + ' contractor immediately. Based on a $' + leadValue + ' average missed lead value for ' + tradeSelected + ' (Contractor Magazine 2024).';
  document.getElementById('cta-title').textContent = 'Fix the $' + monthlyLoss.toLocaleString() + '/month leak — get your messages tonight';
}

function submitEmail() {
  const email = document.getElementById('email-input').value.trim();
  if (!email || !email.includes('@')) return;
  fetch('https://formspree.io/f/mqewegqy', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email, source: 'Revenue Leak Calculator', trade: tradeSelected })
  }).catch(() => {});
  document.getElementById('email-confirm').style.display = 'block';
  document.getElementById('email-input').disabled = true;
}

updateCalc();
</script>
</body>
</html>


