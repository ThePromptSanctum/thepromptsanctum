  .price-note { font-size: 13px; color: var(--muted); display: block; margin-top: 2px; }
  .buy-btn { display: block; width: 100%; padding: 14px; background: var(--navy); color: var(--white); border: none; border-radius: var(--radius-lg); font-size: 15px; font-weight: 500; cursor: pointer; text-align: center; text-decoration: none; margin-bottom: 10px; }
  .buy-btn:hover { opacity: 0.9; }
  .buy-btn.secondary { background: var(--card); color: var(--text); border: 0.5px solid var(--border); }
  .access-section { margin-top: 1.5rem; border-top: 0.5px solid var(--border); padding-top: 1.5rem; }
  .access-title { font-size: 14px; font-weight: 500; color: var(--text); margin: 0 0 4px; }
  .access-sub { font-size: 12px; color: var(--muted); margin: 0 0 10px; line-height: 1.5; }
  .access-row { display: flex; gap: 8px; }
  .access-row input { flex: 1; font-family: monospace; text-transform: uppercase; }
  .access-row button { padding: 10px 16px; background: var(--navy); color: var(--white); border: none; border-radius: var(--radius); font-size: 14px; font-weight: 500; cursor: pointer; }
  .code-error { font-size: 12px; color: var(--danger); margin: 6px 0 0; display: none; }
  .loading-msg { text-align: center; padding: 2rem; color: var(--muted); font-size: 14px; }
  .error-msg { background: #fcebeb; color: var(--danger); border-radius: var(--radius); padding: 1rem; font-size: 13px; margin-top: 1rem; }
  .report-section { display: none; }
  .report-section.visible { display: block; }
  .report-card { background: var(--card); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 10px; }
  .report-text { font-size: 13px; color: var(--text); line-height: 1.8; white-space: pre-wrap; }
  .save-btn { display: block; width: 100%; padding: 13px; background: var(--card); color: var(--text); border: 0.5px solid var(--border); border-radius: var(--radius-lg); font-size: 14px; font-weight: 500; cursor: pointer; text-align: center; margin-top: 0.5rem; }
  .save-btn:hover { background: var(--bg); }
  .footer { text-align: center; padding: 2rem 0 1rem; font-size: 12px; color: var(--hint); }
  .footer a { color: var(--gold); text-decoration: none; }
  @media (max-width: 480px) {
    .two-col { grid-template-columns: 1fr; }
    h1 { font-size: 20px; }
  }
  @media print {
    .top-bar, .kit-header, #form-section, .locked-section, .paywall-card, .access-section, .save-btn, .footer, hr { display: none !important; }
    .output-section { display: block !important; }
    .report-section { display: block !important; }
    body { background: white; }
    .report-card { border: none; padding: 0; }
  }
</style>
</head>
<body>

<div class="top-bar">
  <a href="index.html">← Free Revenue Leak Calculator</a>
  &nbsp;·&nbsp;
  <a href="https://payhip.com/ThePromptSanctum">Shop All Products ↗</a>
</div>

<div class="page">
  <div class="kit-header">
    <h1>Missed Call Message Kit <span class="free-badge">3 messages free</span></h1>
    <p class="sub">Answer 6 questions. Get personalized messages to send tonight. Copy, paste, send — reuse forever.</p>
  </div>

  <div id="form-section">
    <p class="step-label">Your business — 6 questions</p>
    <div class="progress-bar"><div class="progress-fill" id="progress" style="width:0%"></div></div>

    <div class="two-col">
      <div class="field-group">
        <label for="biz-name">Business name</label>
        <input type="text" id="biz-name" placeholder="e.g. Rivera HVAC" oninput="updateProgress()">
      </div>
      <div class="field-group">
        <label for="owner-name">Your first name</label>
        <input type="text" id="owner-name" placeholder="e.g. Marco" oninput="updateProgress()">
      </div>
    </div>

    <div class="two-col">
      <div class="field-group">
        <label for="trade">Your trade</label>
        <select id="trade" onchange="updateProgress()">
          <option value="">Select trade...</option>
          <option>HVAC</option>
          <option>Plumbing</option>
          <option>Electrical</option>
          <option>Roofing</option>
          <option>Cleaning</option>
          <option>Other trades</option>
        </select>
      </div>
      <div class="field-group">
        <label for="service-area">Service area</label>
        <input type="text" id="service-area" placeholder="e.g. Riverside, CA" oninput="updateProgress()">
      </div>
    </div>

    <div class="field-group">
      <label for="hours">Business hours + after-hours emergencies?</label>
      <input type="text" id="hours" placeholder="e.g. Mon-Fri 7am-6pm, Sat 8am-2pm — yes emergencies after hours" oninput="updateProgress()">
    </div>

    <div class="field-group">
      <label>Communication tone</label>
      <div class="tone-grid">
        <button class="tone-btn" id="tone-formal" onclick="selectTone('formal')">
          <span class="t-title">Professional and formal</span>
          <span class="t-desc">Clean, direct, business-like</span>
        </button>
        <button class="tone-btn" id="tone-casual" onclick="selectTone('casual')">
          <span class="t-title">Friendly and casual</span>
          <span class="t-desc">Warm, personal, conversational</span>
        </button>
      </div>
    </div>

    <div class="field-group">
      <label for="customer-type">Typical customer</label>
      <select id="customer-type" onchange="updateProgress()">
        <option value="">Select customer type...</option>
        <option>Homeowners</option>
        <option>Landlords and property managers</option>
        <option>Both homeowners and property managers</option>
      </select>
    </div>

    <button class="gen-btn" id="gen-btn" onclick="generateMessages()" disabled>
      Generate my 3 free messages ↗
    </button>
  </div>

  <hr>

  <div class="output-section" id="output-section">
    <p class="out-title" id="out-title">Your 3 free personalized messages</p>
    <p class="out-sub">Copy each into your phone notes. Send manually when you miss a call. Reuse for any customer, any time.</p>
    <div id="messages-container"></div>

    <div class="locked-section" id="locked-section" style="display:none;">
      <p class="locked-title">Messages 4 and 5 — included in the $97 package</p>

      <div class="locked-card">
        <p class="locked-label">Message 4 — confirmation</p>
        <p class="locked-when">Sends when the customer replies — closes the loop and sets a callback time</p>
        <p class="locked-preview">Got it — flagged as urgent. Marco will get back to you as soon as he is free. — Rivera HVAC Field Agent</p>
      </div>

      <div class="locked-card">
        <p class="locked-label">Message 5 — contractor brief</p>
        <p class="locked-when">Sends to YOUR phone when the conversation is complete — issue, urgency, address, best callback time before you dial</p>
        <p class="locked-preview">Field Agent Brief — Client: (951) 555-1234 | AC not working, 87 degrees, infant home | Urgency: HIGH | Available all afternoon</p>
      </div>

      <div class="paywall-card">
        <p class="pw-title">Get all 5 messages + the complete automation build</p>
        <p class="pw-sub">The $97 package gives you messages 4 and 5, the complete 36-step automation build guide so this system runs automatically 24/7, and your personalized business report with your recovery timeline and ROI.</p>
        <ul class="include-list">
          <li>Message 4 — confirmation (closes the loop with the customer automatically)</li>
          <li>Message 5 — contractor brief SMS to your phone (issue, urgency, address, callback time)</li>
          <li>36-step build guide — complete Twilio + Make.com automation, plain English, step by step</li>
          <li>Personalized business report — your recovery timeline, ROI calculation, and 90-day plan</li>
          <li>Nomorobo spam filter included — blocks robocalls before the system texts them (~$0.50/mo)</li>
        </ul>
        <div class="cost-warn">Important: The $97 build package requires $15 to start + approximately $20-22/month in tool subscriptions (Twilio ~$15/mo, Make.com free, Claude API ~$1-3/mo, spam filter ~$0.50/mo). These are your costs — stated clearly upfront, no surprises.</div>
        <div class="price-row">
          <span class="price-big">$97</span>
          <span class="price-note">one-time · build guide PDF delivered instantly by email · access code included</span>
        </div>
        <a class="buy-btn" href="https://payhip.com/ThePromptSanctum" target="_blank">Get the complete $97 package ↗</a>
        <a class="buy-btn secondary" href="index.html">← Back to the free revenue calculator</a>

        <div class="access-section">
          <p class="access-title">Already purchased? Unlock your business report here</p>
          <p class="access-sub">After buying on Payhip you receive your build guide PDF by email plus an access code. Enter it below. You will need to have filled in your business details above first — this ensures your report uses your exact numbers.</p>
          <div class="access-row">
            <input type="text" id="access-code" placeholder="Enter access code">
            <button onclick="unlockReport()">Unlock</button>
          </div>
          <p class="code-error" id="code-error">Code not recognized. Check your Payhip delivery email and try again.</p>
        </div>
      </div>
    </div>

    <div class="report-section" id="report-section">
      <hr>
      <p class="out-title" id="report-title">Your personalized business report</p>
      <p class="out-sub">Generated from your business details. Use your browser's print function to save as PDF.</p>
      <div id="report-container"></div>
      <button class="save-btn" onclick="window.print()">Save as PDF (browser print) ↗</button>
    </div>
  </div>

  <div class="footer">
    <p>© 2026 The Prompt Sanctum · <a href="https://payhip.com/ThePromptSanctum">payhip.com/ThePromptSanctum</a></p>
    <p style="margin-top:4px;">IndOp Series — AI tools built for independent operators</p>
  </div>
</div>

<script>
const ANTHROPIC_PROXY = 'https://api.anthropic.com/v1/messages';
const MODEL = 'claude-sonnet-4-20250514';
const VALID_CODES = ['TPS2026','INDOP47','RIVERA97'];
let selectedTone = '';

function selectTone(t) {
  selectedTone = t;
  document.getElementById('tone-formal').classList.toggle('selected', t === 'formal');
  document.getElementById('tone-casual').classList.toggle('selected', t === 'casual');
  updateProgress();
}

function getFields() {
  return {
    biz: document.getElementById('biz-name').value.trim(),
    owner: document.getElementById('owner-name').value.trim(),
    trade: document.getElementById('trade').value,
    area: document.getElementById('service-area').value.trim(),
    hours: document.getElementById('hours').value.trim(),
    tone: selectedTone,
    customers: document.getElementById('customer-type').value
  };
}

function updateProgress() {
  const f = getFields();
  const vals = Object.values(f);
  const filled = vals.filter(v => v).length;
  document.getElementById('progress').style.width = Math.round((filled / vals.length) * 100) + '%';
  document.getElementById('gen-btn').disabled = !vals.every(v => v);
}

function copyText(id, btn) {
  navigator.clipboard.writeText(document.getElementById(id).textContent).then(() => {
    btn.textContent = 'Copied';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });
}

async function callClaude(system, userMsg, maxTokens) {
  const resp = await fetch(ANTHROPIC_PROXY, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: MODEL, max_tokens: maxTokens,
      system: system,
      messages: [{ role: 'user', content: userMsg }]
    })
  });
  const data = await resp.json();
  return data.content?.[0]?.text || '';
}

async function generateMessages() {
  const f = getFields();
  const tone = f.tone === 'formal' ? 'professional and formal' : 'friendly and casual';
  document.getElementById('gen-btn').disabled = true;
  document.getElementById('gen-btn').textContent = 'Generating...';
  document.getElementById('output-section').classList.add('visible');
  document.getElementById('messages-container').innerHTML = '<div class="loading-msg">Writing your messages — about 10 seconds...</div>';
  document.getElementById('locked-section').style.display = 'none';

  const system = `You are an expert copywriter for solo trades contractors. Write exactly 3 personalized missed-call text messages.

BUSINESS: ${f.biz} | OWNER: ${f.owner} | TRADE: ${f.trade} | AREA: ${f.area} | HOURS: ${f.hours} | TONE: ${tone} | CUSTOMERS: ${f.customers}

MSG1: Introduce as field agent for ${f.biz}. ${f.owner} missed their call. Ask what is going on, how urgent, and when is a good time — all in one short message. Under 3 sentences. Never say AI, automated, or robot.
MSG2: Only if customer reply is missing callback time or address. Ask for both in one short question. Under 2 sentences.
MSG3: Fires 35 minutes after MSG1 if no reply. Gentle second attempt. Mention ${f.biz}. Human feeling. Under 2 sentences.

${f.customers.includes('andlord') ? 'Landlords care most about speed and cost.' : 'Homeowners care about comfort and family safety.'}
${tone === 'professional and formal' ? 'Use clean professional language.' : 'Use warm conversational language.'}

RESPOND EXACTLY:
MSG1:
[text]

MSG2:
[text]

MSG3:
[text]`;

  try {
    const raw = await callClaude(system, 'Generate now.', 600);
    const m1 = (raw.match(/MSG1:\s*([\s\S]*?)(?=MSG2:|$)/) || [])[1]?.trim() || '';
    const m2 = (raw.match(/MSG2:\s*([\s\S]*?)(?=MSG3:|$)/) || [])[1]?.trim() || '';
    const m3 = (raw.match(/MSG3:\s*([\s\S]*?)$/) || [])[1]?.trim() || '';

    document.getElementById('out-title').textContent = 'Your 3 free messages — ' + f.biz;
    const msgs = [
      { label: 'Message 1 — initial outreach', when: 'Send within 90 seconds of a missed call', id: 'msg1', text: m1 },
      { label: 'Message 2 — follow-up', when: 'Send only if their reply is missing callback time or location', id: 'msg2', text: m2 },
      { label: 'Message 3 — recovery nudge', when: 'Send 35 minutes after message 1 if no reply', id: 'msg3', text: m3 },
    ];
    document.getElementById('messages-container').innerHTML = msgs.map(m =>
      `<div class="msg-card"><p class="msg-label">${m.label}</p><p class="msg-when">${m.when}</p><p class="msg-text" id="${m.id}">${m.text}</p><button class="copy-btn" onclick="copyText('${m.id}',this)">Copy</button></div>`
    ).join('');
    document.getElementById('locked-section').style.display = 'block';
  } catch(err) {
    document.getElementById('messages-container').innerHTML = `<div class="error-msg">Something went wrong. Please try again.<br><small>${err.message}</small></div>`;
  }
  document.getElementById('gen-btn').disabled = false;
  document.getElementById('gen-btn').textContent = 'Regenerate messages ↗';
}

async function unlockReport() {
  const code = document.getElementById('access-code').value.trim().toUpperCase();
  const f = getFields();
  if (!VALID_CODES.includes(code)) {
    const el = document.getElementById('code-error');
    el.textContent = 'Code not recognized. Check your Payhip delivery email and try again.';
    el.style.display = 'block';
    return;
  }
  if (!f.biz || !f.trade) {
    const el = document.getElementById('code-error');
    el.textContent = 'Please fill in your business details above first, then enter your code.';
    el.style.display = 'block';
    return;
  }
  document.getElementById('code-error').style.display = 'none';
  const reportSection = document.getElementById('report-section');
  reportSection.classList.add('visible');
  document.getElementById('report-container').innerHTML = '<div class="loading-msg">Generating your personalized business report — about 15 seconds...</div>';

  const system = `Generate a detailed personalized business report for a solo ${f.trade} contractor.
BUSINESS: ${f.biz} | OWNER: ${f.owner} | TRADE: ${f.trade} | AREA: ${f.area} | CUSTOMERS: ${f.customers}

Write 4 clear sections:

SECTION 1 — BUSINESS HEALTH SNAPSHOT
Compare to industry benchmarks for solo ${f.trade} operators. Cover lead capture rate, average response time, review count, and customer retention rate. Show estimated current position vs industry average vs top 10%. Use specific numbers.

SECTION 2 — YOUR REVENUE RECOVERY ROADMAP
List 5 highest-ROI actions ranked by monthly dollar recovery. For each: estimated monthly recovery, one-time setup cost, monthly running cost, payback period in days. Specific to ${f.trade} in ${f.area}.

SECTION 3 — YOUR 90-DAY PLAN
Month 1: missed call system. Month 2: next highest ROI fix. Month 3: third fix. For each show projected monthly recovery added and running total. Be specific.

SECTION 4 — YOUR COMPETITIVE POSITION
How does a solo ${f.trade} contractor in ${f.area} compare to competitors right now? What are top operators doing differently? Name specific actions, not generic advice.

Write directly to ${f.owner}. Use specific numbers throughout. Be a trusted business advisor.`;

  try {
    const text = await callClaude(system, 'Generate the full report now.', 1500);
    document.getElementById('report-title').textContent = 'Your business report — ' + f.biz;
    document.getElementById('report-container').innerHTML =
      `<div class="report-card"><p class="report-text">${text.replace(/\n/g,'<br>')}</p></div>`;
  } catch(err) {
    document.getElementById('report-container').innerHTML = `<div class="error-msg">Report generation failed. Please try again.</div>`;
  }
}
</script>
</body>
</html>


